    <script>
        const prices = {
            wall: { first: 14300, additional: 11550 },
            auto: { first: 25300, additional: 22550 },
            ceiling: { first: 38500, additional: 31900 }
        };
        const options = {
            coat: 3300,
            outdoor: 5500
        };
        const qty = { wall: 0, auto: 0, ceiling: 0 };
 
        function changeQty(type, delta) {
            qty[type] = Math.max(0, qty[type] + delta);
            document.getElementById('qty-' + type).textContent = qty[type];
            calcTotal();
        }
 
        function calcTotal() {
            const totalUnits = qty.wall + qty.auto + qty.ceiling;
            let total = 0;
            let totalWithoutDiscount = 0;
            const details = [];
 
            for (const [type, count] of Object.entries(qty)) {
                if (count === 0) continue;
                const p = prices[type];
                const label = type === 'wall' ? '壁掛け（通常）' : type === 'auto' ? '壁掛け（お掃除機能付）' : '天井埋込';
 
                if (count === 1) {
                    total += p.first;
                    totalWithoutDiscount += p.first;
                    details.push(label + ' × 1台 = ¥' + p.first.toLocaleString());
                } else {
                    const subtotal = p.first + p.additional * (count - 1);
                    const fullPrice = p.first * count;
                    total += subtotal;
                    totalWithoutDiscount += fullPrice;
                    details.push(label + ' × ' + count + '台 = ¥' + subtotal.toLocaleString() + '（2台目以降割引適用）');
                }
            }
 
            const coatChecked = document.getElementById('opt-coat').checked;
            const outdoorChecked = document.getElementById('opt-outdoor').checked;
 
            if (coatChecked && totalUnits > 0) {
                const coatTotal = options.coat * totalUnits;
                total += coatTotal;
                totalWithoutDiscount += coatTotal;
                details.push('防カビコーティング × ' + totalUnits + '台 = ¥' + coatTotal.toLocaleString());
            }
            if (outdoorChecked && totalUnits > 0) {
                const outdoorTotal = options.outdoor * totalUnits;
                total += outdoorTotal;
                totalWithoutDiscount += outdoorTotal;
                details.push('室外機洗浄 × ' + totalUnits + '台 = ¥' + outdoorTotal.toLocaleString());
            }
 
            document.getElementById('total-price').textContent = '¥' + total.toLocaleString();
 
            const detailEl = document.getElementById('estimate-detail');
            if (details.length > 0) {
                detailEl.innerHTML = details.map(d => '<p>' + d + '</p>').join('');
            } else {
                detailEl.innerHTML = '';
            }
 
            const discount = totalWithoutDiscount - total;
            const badge = document.getElementById('discount-badge');
            if (discount > 0) {
                document.getElementById('discount-amount').textContent = '¥' + discount.toLocaleString();
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }
        }
 
        // Scroll animation
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, { threshold: 0.1 });
 
        document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
    </script>
 
